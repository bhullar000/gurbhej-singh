/*
 * Pipeline configuration + execution profiles.
 * `-profile docker`   → run locally with containers
 * `-profile awsbatch` → run long jobs on AWS Batch (custom AMI + launch template compute env)
 */

manifest {
    name            = 'nextflow-genomics-demo'
    author          = 'Gurbhej Singh'
    description     = 'Minimal nf-core-style QC pipeline (FastQC + MultiQC) runnable on AWS Batch'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.04.0'
    version         = '1.0.0'
}

params {
    input  = "${projectDir}/assets/samplesheet.csv"
    outdir = 'results'
}

// Sensible defaults + resource labels (nf-core convention)
process {
    cpus   = 2
    memory = 4.GB
    time   = 4.h

    withLabel: process_low    { cpus = 2;  memory = 4.GB  }
    withLabel: process_medium { cpus = 6;  memory = 12.GB }
    withLabel: process_high   { cpus = 12; memory = 36.GB; time = 12.h }
}

profiles {
    docker {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
    }

    // Long-running jobs on AWS Batch — the compute environment (custom AMI +
    // launch template + job queue) is provisioned by the aws-deploy-template repo.
    awsbatch {
        process.executor = 'awsbatch'
        process.queue    = 'genomics-job-queue'

        aws.region              = 'us-east-1'
        aws.batch.cliPath       = '/usr/local/bin/aws'
        aws.batch.maxParallelTransfers = 8

        workDir = 's3://my-genomics-bucket/nextflow-work'
        docker.enabled = true
    }
}

// Execution reports (great for showing clients runtime/cost profiles)
timeline { enabled = true; file = "${params.outdir}/pipeline_info/timeline.html" }
report   { enabled = true; file = "${params.outdir}/pipeline_info/report.html"   }
trace    { enabled = true; file = "${params.outdir}/pipeline_info/trace.txt"     }
